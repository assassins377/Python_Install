{
    "_version": 2,
    "categories": {
        "СИСТЕМНЫЕ КОМПОНЕНТЫ": [
            {
                "name": "Microsoft .NET Framework 4.8",
                "cmd": "software\\net48.exe /q /norestart",
                "desc": "Необходимый компонент для работы многих программ на Windows.",
                "icon": "icons/system.png",
                "detect": {
                    "net_framework_release": 528040
                },
                "timeout": 600,
                "retry": 0,
                "uninstall_cmd": ""
            },
            {
                "name": "DirectX (Июнь 2010)",
                "cmd": "software\\directx_setup.exe /silent",
                "desc": "Набор библиотек для запуска игр и работы с мультимедиа.",
                "icon": "icons/system.png",
                "detect": {
                    "path": "%SystemRoot%\\System32\\d3dx9_43.dll"
                },
                "timeout": 300,
                "retry": 1,
                "uninstall_cmd": ""
            },
            {
                "name": "Microsoft Visual C++ 2005-2022 Redistributable",
                "cmd": "software\\vcredist_all.exe /silent",
                "desc": "Полный набор Visual C++ Redistributable (2005–2022), x86 и x64.",
                "icon": "icons/system.png",
                "detect": {
                    "registry_name": "Microsoft Visual C++ 2022"
                },
                "timeout": 600,
                "retry": 1,
                "uninstall_cmd": ""
            }
        ],
        "ИНТЕРНЕТ И БРАУЗЕРЫ": [
            {
                "name": "Google Chrome",
                "cmd": "software\\chrome_installer.exe --silent --install",
                "desc": "Один из самых популярных и быстрых веб-браузеров.",
                "icon": "icons/chrome.png",
                "detect": {
                    "registry_name": "Google Chrome",
                    "min_version": "120.0"
                },
                "depends_on": ["Microsoft .NET Framework 4.8"],
                "retry": 2,
                "uninstall_cmd": "software\\chrome_installer.exe --uninstall --force-uninstall"
            },
            {
                "name": "Telegram Desktop",
                "cmd": "software\\telegram.exe /VERYSILENT",
                "desc": "Официальный клиент мессенджера Telegram для ПК.",
                "icon": "icons/tg.png",
                "detect": {
                    "registry_name": "Telegram Desktop"
                },
                "retry": 2,
                "uninstall_cmd": "software\\telegram.exe /VERYSILENT /UNINSTALL"
            }
        ],
        "ОФИСНОЕ ПО": [
            {
                "name": "LibreOffice",
                "cmd": "software\\libreoffice.msi /quiet",
                "desc": "Свободный офисный пакет: документы, таблицы, презентации.",
                "icon": "icons/system.png",
                "detect": {
                    "registry_name": "LibreOffice"
                },
                "depends_on": ["Microsoft Visual C++ 2005-2022 Redistributable"],
                "retry": 1
            }
        ],
        "ТВИКИ ОС": [
            {
                "name": "Отключить телеметрию Windows",
                "cmd": "tweaks\\disable_telemetry.ps1",
                "desc": "Отключает сбор диагностических данных и телеметрию Windows.",
                "icon": "icons/system.png",
                "detect": {
                    "always_runnable": true
                },
                "retry": 0
            }
        ]
    }
}