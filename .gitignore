# Игнорируем тяжелые файлы программ и твиков
software/
tweaks/

# Кеш извлечённых иконок (генерируется при запуске)
icons/cache/

# Игнорируем логи и временные базы
*.log
MInstAll/

# Игнорируем папки компиляции PyInstaller
build/
dist/
*.spec

# Игнорируем кэш Python и виртуальные окружения
__pycache__/
*.pyc
venv_x86/
venv_x64/
venv/
.venv/

# Метаданные setuptools (генерируются при сборке)
*.egg-info/

# Настройки редактора
.vscode/

# Кеши инструментов разработки
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Отчёты о покрытии (генерируются pytest --cov)
.coverage
coverage.xml
htmlcov/

# Конфиг/скиллы AI-ассистента (Kilo Code) — не относится к программе
.kilo/

# Внутренние рабочие заметки по аудиту (не пользовательская документация)
ANALYSIS.md